import { useEffect, useState } from "react";
import TopNav from "../components/TopNav";
import Footer from "../components/Footer";
import { api } from "../lib/api";
import { History as HistoryIcon, Trash2, Image as ImageIcon, ArrowRight } from "lucide-react";
import { toast } from "sonner";
import { Link } from "react-router-dom";

const LOGO_URL =
  "/raven-logo.png";

function fmtKB(bytes) {
  if (!bytes) return "0 KB";
  if (bytes >= 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(2) + " MB";
  return (bytes / 1024).toFixed(0) + " KB";
}
function fmtDate(iso) {
  const d = new Date(iso);
  return d.toLocaleString(undefined, { month: "short", day: "numeric", year: "numeric", hour: "2-digit", minute: "2-digit" });
}

export default function History() {
  const [jobs, setJobs] = useState([]);
  const [loading, setLoading] = useState(true);

  const load = async () => {
    try {
      const { data } = await api.get("/jobs");
      setJobs(data);
    } catch {
      toast.error("Failed to load history");
    } finally { setLoading(false); }
  };

  useEffect(() => { load(); }, []);

  const remove = async (id) => {
    try {
      await api.delete(`/jobs/${id}`);
      setJobs((j) => j.filter((x) => x.id !== id));
      toast.success("Removed");
    } catch { toast.error("Could not remove"); }
  };

  const clearAll = async () => {
    if (!confirm("Clear all history?")) return;
    try {
      await api.delete("/jobs");
      setJobs([]);
      toast.success("History cleared");
    } catch { toast.error("Could not clear"); }
  };

  return (
    <div className="min-h-screen">
      <TopNav />
      <main className="max-w-5xl mx-auto px-4 md:px-8 py-10" data-testid="history-page">
        <div className="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-10">
          <div className="flex items-center gap-5">
            <img
              src={LOGO_URL}
              alt="Raven Sharp"
              className="h-20 w-auto object-contain logo-plate"
            />
            <div>
              <div className="label-tiny mb-2">Activity log</div>
              <h1 className="font-display text-5xl tracking-tight uppercase leading-none">History</h1>
            </div>
          </div>
          {jobs.length > 0 && (
            <button onClick={clearAll} className="btn-ghost self-start sm:self-end" data-testid="clear-history-button">
              <Trash2 size={14} /> Clear all
            </button>
          )}
        </div>

        {loading ? (
          <div className="text-raven-muted">Loading…</div>
        ) : jobs.length === 0 ? (
          <div className="surface p-16 text-center" data-testid="history-empty-state">
            <div className="mx-auto h-14 w-14 rounded-full bg-raven-violet/15 border border-raven-violet/30 flex items-center justify-center mb-5">
              <HistoryIcon size={22} className="text-raven-violetBright" />
            </div>
            <h3 className="font-display text-3xl tracking-tight uppercase mb-2">No jobs yet</h3>
            <p className="text-raven-muted text-sm max-w-md mx-auto mb-6">
              Optimised images you process will appear here for quick reference.
            </p>
            <Link to="/" className="btn-primary inline-flex" data-testid="go-to-optimiser-link">
              Start optimising <ArrowRight size={16} />
            </Link>
          </div>
        ) : (
          <div className="space-y-3" data-testid="history-list">
            {jobs.map((j) => {
              const saved = j.original_size - j.output_size;
              const pct = j.original_size > 0 ? Math.round((saved / j.original_size) * 100) : 0;
              return (
                <div key={j.id} className="surface p-4 flex flex-col sm:flex-row sm:items-center gap-4 hover:border-white/15 transition-colors" data-testid={`history-row-${j.id}`}>
                  <div className="h-12 w-12 rounded-lg bg-raven-violet/10 border border-raven-violet/20 flex items-center justify-center shrink-0">
                    <ImageIcon size={18} className="text-raven-violetBright" />
                  </div>
                  <div className="flex-1 min-w-0">
                    <div className="text-sm truncate font-medium">{j.name}</div>
                    <div className="label-tiny mt-1">{fmtDate(j.created_at)}</div>
                  </div>
                  <div className="grid grid-cols-3 gap-6 text-sm">
                    <div>
                      <div className="label-tiny mb-1">Output</div>
                      <div>{j.width}×{j.height}</div>
                    </div>
                    <div>
                      <div className="label-tiny mb-1">DPI / Format</div>
                      <div>{j.dpi} · {j.format.toUpperCase()}</div>
                    </div>
                    <div>
                      <div className="label-tiny mb-1">Size</div>
                      <div>
                        {fmtKB(j.output_size)}{" "}
                        <span className={pct > 0 ? "text-emerald-400" : "text-raven-muted"}>
                          ({pct > 0 ? "−" : "+"}{Math.abs(pct)}%)
                        </span>
                      </div>
                    </div>
                  </div>
                  <button onClick={() => remove(j.id)} className="text-raven-muted hover:text-red-400 transition-colors" data-testid={`delete-job-${j.id}`}>
                    <Trash2 size={16} />
                  </button>
                </div>
              );
            })}
          </div>
        )}
      </main>
      <Footer />
    </div>
  );
}
